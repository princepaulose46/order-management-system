# ─── Database ────────────────────────────────────────────────────────
# PostgreSQL connection string with connection pool settings.
#   connection_limit = max_db_connections / number_of_app_instances
#   pool_timeout     = seconds a query waits for a free connection before erroring
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?connection_limit=20&pool_timeout=10"

# Direct connection URL — bypasses external connection poolers (e.g., PgBouncer)
# for running migrations. Locally, same as DATABASE_URL without pool params.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ─── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Background Jobs ─────────────────────────────────────────────────
# Set to 'false' in multi-instance web servers to run the cron scheduler on a single dedicated task/container.
ENABLE_SCHEDULER=true


# ─── Security ────────────────────────────────────────────────────────
# Rate limiting configuration (default: 200 requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Express 'trust proxy' setting (1, true, or a proxy IP/CIDR if behind Nginx/Cloudflare/ALB)
TRUST_PROXY=1

# ─── Redis (Optional for Distributed Rate Limiting) ─────────────────
# If set, rate limiting uses Redis instead of local in-memory store.
# REDIS_URL=redis://localhost:6379
# OR configure host/port individually:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=


